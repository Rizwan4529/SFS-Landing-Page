# Waitlist form submission endpoint.
# The form POSTs JSON with name, email, signedUpAt, UTM fields, referrer, and landingPage.
# Point it at Google Apps Script (see scripts/waitlist-apps-script.gs) or another webhook:
#   - Google Apps Script:   https://script.google.com/macros/s/your-deployment-id/exec
#   - Formspree:            https://formspree.io/f/your-form-id
#   - SheetDB:              https://sheetdb.io/api/v1/your-api-id
#
# Leave unset during development; the form still validates and shows all states,
# but submissions are not sent anywhere (a console warning is logged).
VITE_WAITLIST_ENDPOINT=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX).
# Leave unset to disable analytics in development.
VITE_GA_MEASUREMENT_ID=

# Optional explainer video URL override (YouTube, Vimeo, Google Drive preview embed, or local path).
# Default: Google Drive embed for SFS-explainer.mp4 (see src/lib/video.ts).
# VITE_EXPLAINER_VIDEO_URL=
